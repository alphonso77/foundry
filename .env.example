# ─────────────────────────────────────────────────────────────────────────────
# Foundry — local environment template
# Copy to `.env` (root) for `npm run dev`; docker-compose reads these too.
# ─────────────────────────────────────────────────────────────────────────────

# --- Generator / API server (packages/server) ---
# Port the Express API listens on.
SERVER_PORT=4000

# Auth bypass. In dev this is `true`: every route is open and the real OAuth
# check is skipped (see packages/server/src/auth.ts for the seam where a real
# IdP would slot in). NEVER ship `true` to a reachable environment.
AUTH_DISABLED=true

# Where the FolderResolver reads blueprints from. Defaults to <repo>/blueprints
# when unset; override only if blueprints live elsewhere.
# FOUNDRY_BLUEPRINTS_DIR=/abs/path/to/blueprints

# --- CORS / portal origin ---
# The Vite dev server origin the API allows cross-origin requests from.
PORTAL_ORIGIN=http://localhost:5173

# --- Portal frontend (apps/portal-web) ---
# Base URL the SPA calls for the API. Consumed by Vite at build/serve time.
VITE_API_BASE_URL=http://localhost:4000

# --- Postgres ---
# NOTE: Postgres is present to mirror the real topology and to back the
# *generated* projects' eventual use. The generator itself does NOT need a DB —
# generation never opens a connection, so a down database does not block it.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=foundry
POSTGRES_PASSWORD=foundry
POSTGRES_DB=foundry
DATABASE_URL=postgres://foundry:foundry@localhost:5432/foundry
