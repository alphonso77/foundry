# {{serviceName}} — environment configuration

# HTTP
PORT=3000
OAUTH_ISSUER=https://auth.example.com

# Datastore ({{datastore}})
DATABASE_URL=postgres://postgres:postgres@localhost:5432/{{kebabCase serviceName}}

# Optional extra OAuth client, registered by `npm run db:init` on top of the default
# seeded client. No-op unless SEED_CLIENT_ID is set. Example: register Foundry's portal.
#   SEED_CLIENT_ID=foundry-portal
#   SEED_CLIENT_REDIRECT_URIS=http://localhost:5173/callback   # comma-separated
#   SEED_CLIENT_SECRET=                                        # unset = public client (PKCE)

{{#ifEquals tokenStrategy "local-jwt"}}
# Local JWT signing
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
{{else}}
# External IdP backing
IDP_ISSUER=https://idp.example.com
IDP_CLIENT_ID=
IDP_CLIENT_SECRET=
{{/ifEquals}}
{{#ifIncludes integrations "stripe"}}
# Stripe integration
STRIPE_API_KEY=
{{/ifIncludes}}
{{#ifIncludes integrations "salesforce"}}
# Salesforce integration
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
{{/ifIncludes}}
{{#ifIncludes integrations "hubspot"}}
# HubSpot integration
HUBSPOT_API_KEY=
{{/ifIncludes}}
