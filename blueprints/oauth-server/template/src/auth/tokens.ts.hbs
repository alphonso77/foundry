import { randomUUID } from 'crypto';
import { config } from '../config';

// Field names follow RFC 6749 §5.1 (snake_case) so Swagger UI and OAuth clients
// can parse the response without mapping.
export interface TokenPair {
  access_token: string;
  refresh_token: string;
  token_type: 'Bearer';
  expires_in: number;
}

{{#ifEquals tokenStrategy "local-jwt"}}
import jwt from 'jsonwebtoken';

export function issueTokens(subject: string, scope: string[]): TokenPair {
  const access_token = jwt.sign(
    { scope, type: 'access' },
    config.jwtSecret,
    { subject, issuer: config.issuer, expiresIn: config.accessTokenTtlSeconds },
  );
  const refresh_token = jwt.sign(
    { scope, type: 'refresh', jti: randomUUID() },
    config.jwtSecret,
    { subject, issuer: config.issuer, expiresIn: config.refreshTokenTtlSeconds },
  );
  return {
    access_token,
    refresh_token,
    token_type: 'Bearer',
    expires_in: config.accessTokenTtlSeconds,
  };
}

export function verifyToken(token: string): jwt.JwtPayload {
  const decoded = jwt.verify(token, config.jwtSecret, { issuer: config.issuer });
  if (typeof decoded === 'string') {
    throw new Error('Unexpected string token payload');
  }
  return decoded;
}
{{else}}
// External IdP token strategy: this service does not mint tokens itself.
// Tokens are issued by the upstream IdP (config.idpIssuer); we exchange codes for them.
export async function exchangeAuthorizationCode(code: string): Promise<TokenPair> {
  // Integration point: POST to `${config.idpIssuer}/oauth/token` with
  // config.idpClientId / config.idpClientSecret. Stubbed for the prototype.
  throw new Error(
    `External IdP exchange not implemented (issuer=${config.idpIssuer}, code=${code}, nonce=${randomUUID()})`,
  );
}
{{/ifEquals}}
